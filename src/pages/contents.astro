---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title="Contents" description="보고 읽은 것들의 기록" />
	</head>
	<body>
		<Header />
		<main>
			<h1>Contents</h1>
			<ul>
				{posts.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`}>
							<span class="title">{post.data.title}</span>
							<span class="meta">
								{post.data.category && (Array.isArray(post.data.category) ? post.data.category : [post.data.category]).map(cat => (
										<span class="category">{cat}</span>
									))}
								<time>{new Date(post.data.pubDate).toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
							</span>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
<style>
	main {
		max-width: 720px;
		margin: 0 auto;
		padding: 4em 1em;
	}
	h1 {
		font-size: 1.2em;
		font-weight: 600;
		margin-bottom: 2em;
	}
	ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0;
	}
	li a {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		padding: 1em 0;
		border-bottom: 1px solid rgba(0,0,0,0.07);
		text-decoration: none;
		color: #222;
		gap: 1em;
	}
	li a:hover .title {
		text-decoration: underline;
	}
	.title {
		font-size: 0.95em;
	}
	.meta {
		display: flex;
		align-items: center;
		gap: 0.8em;
		flex-shrink: 0;
	}
	.category {
		font-size: 0.75em;
		background: #EBEF76;
		padding: 0.2em 0.6em;
		border-radius: 2px;
		color: #333;
	}
	time {
		font-size: 0.8em;
		color: #999;
	}
</style>
